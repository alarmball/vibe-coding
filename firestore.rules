rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }

    match /run_bolt/{recordId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'date', 'distance', 'duration', 'memo',
          'authorId', 'authorName', 'authorPhoto', 'createdAt'
        ])
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.date is string
        && request.resource.data.date.size() == 10
        && request.resource.data.distance is number
        && request.resource.data.distance > 0
        && request.resource.data.duration is number
        && request.resource.data.duration >= 1
        && request.resource.data.memo is string
        && request.resource.data.memo.size() <= 200;
      allow delete: if signedIn() && resource.data.authorId == request.auth.uid;
      allow update: if false;

      match /sparks/{userId} {
        allow read: if true;
        allow create: if signedIn()
          && userId == request.auth.uid
          && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
          && request.resource.data.uid == request.auth.uid;
        allow delete: if signedIn() && userId == request.auth.uid;
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn()
          && request.resource.data.keys().hasOnly(['text', 'authorId', 'authorName', 'createdAt'])
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300;
        allow delete: if signedIn() && resource.data.authorId == request.auth.uid;
        allow update: if false;
      }
    }
  }
}
