rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }

    match /records/{recordId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['title', 'content', 'category', 'authorId', 'authorName', 'createdAt'])
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 60
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 1000
        && request.resource.data.category is string
        && request.resource.data.category.size() <= 20;
      allow update, delete: if false;

      match /sparks/{userId} {
        allow read: if true;
        allow create: if signedIn()
          && userId == request.auth.uid
          && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
          && request.resource.data.uid == request.auth.uid;
        allow delete: if signedIn() && userId == request.auth.uid;
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn()
          && request.resource.data.keys().hasOnly(['text', 'authorId', 'authorName', 'createdAt'])
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300;
        allow delete: if signedIn() && resource.data.authorId == request.auth.uid;
        allow update: if false;
      }
    }
  }
}
